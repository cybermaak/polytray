{
  "name": "polytray",
  "version": "1.1.0",
  "author": {
    "name": "cybermaak",
    "email": "cybermaak@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cybermaak/polytray.git"
  },
  "description": "Local 3D file organizer \u2014 scan, index, search, and preview .obj, .stl, .3mf files",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "dev": "electron-vite dev",
    "profile": "POLYTRAY_PROFILE=50 electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "node build/scripts/postinstall.js",
    "clean": "rm -rf out dist dist-electron",
    "test:e2e": "npm run test:product:e2e",
    "release": "electron-builder --publish always",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "test:product:unit": "node scripts/run-node-tests.mjs tests/product/unit",
    "test:product:e2e": "tsx tests/support/fixtures/generateFixtures.ts && playwright test",
    "test:product": "npm run test:product:unit && npx electron-builder install-app-deps && npm run test:product:e2e",
    "test:repo": "node scripts/run-node-tests.mjs tests/repo",
    "test:dev:ui": "tsx tests/dev/verify-ui.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "electron-log": "^5.4.3",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.1",
    "three": "^0.170.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.polytray.app",
    "productName": "Polytray",
    "afterPack": "build/scripts/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!tests/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      "github"
    ]
  }
}
