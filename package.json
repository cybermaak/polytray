{
  "name": "polytray",
  "version": "1.0.0",
  "description": "Local 3D file organizer — scan, index, search, and preview .obj, .stl, .3mf files",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf out dist dist-electron"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "jszip": "^3.10.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "jsdom": "^28.1.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.polytray.app",
    "productName": "Polytray",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
