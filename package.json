{
  "name": "polytray",
  "version": "1.0.0",
  "author": {
    "name": "cybermaak",
    "email": "cybermaak@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cybermaak/polytray.git"
  },
  "description": "Local 3D file organizer — scan, index, search, and preview .obj, .stl, .3mf files",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf out dist dist-electron",
    "test:e2e": "node tests/generate-fixtures.js && npx playwright test",
    "release": "electron-builder --publish always",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.polytray.app",
    "productName": "Polytray",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!tests/fixtures/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      "github"
    ]
  }
}
